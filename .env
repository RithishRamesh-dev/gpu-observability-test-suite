# .env
# Default environment variables for docker-compose.
# Copy this file and edit for your environment.
# Values here are used when the variable is not already set in your shell.

# Which GPU to test (0-indexed). On a multi-GPU machine set this to the
# GPU you want to stress, e.g. TEST_GPU_INDEX=1
TEST_GPU_INDEX=0

# HuggingFace model ID for the vLLM inference test.
# facebook/opt-125m  — tiny model, downloads ~250 MB, good for CI
# mistralai/Mistral-7B-Instruct-v0.2  — realistic 7B model, needs ≥16 GB VRAM
VLLM_MODEL=mistralai/Mistral-7B-Instruct-v0.2

# nvidia-smi poll interval in seconds. 1.0 is fine for most tests.
# Lower values (0.5) give smoother metric curves but more data.
COLLECTOR_INTERVAL=1.0

# Set to true to build the image with vLLM included.
# docker compose build --build-arg INSTALL_VLLM=true
INSTALL_VLLM=false