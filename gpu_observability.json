{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "title": "GPU Observability Dashboard",
  "uid": "gpu-observability-v1",
  "version": 1,
  "schemaVersion": 37,
  "refresh": "5s",
  "time": { "from": "now-1h", "to": "now" },
  "tags": ["gpu", "nvidia", "dcgm", "observability"],
  "templating": {
    "list": [
      {
        "name": "gpu",
        "type": "query",
        "label": "GPU",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(DCGM_FI_DEV_GPU_TEMP, gpu)",
        "multi": true,
        "includeAll": true,
        "current": { "selected": true, "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "GPU Occupancy (%)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "DCGM_FI_PROF_SM_OCCUPANCY{gpu=~\"$gpu\"} * 100",
          "legendFormat": "GPU {{gpu}} SM Occupancy"
        },
        {
          "expr": "DCGM_FI_PROF_SM_ACTIVE{gpu=~\"$gpu\"} * 100",
          "legendFormat": "GPU {{gpu}} SM Active"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 40 },
              { "color": "green", "value": 60 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Tensor Core & FP Pipeline Activity (%)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "DCGM_FI_PROF_PIPE_TENSOR_ACTIVE{gpu=~\"$gpu\"} * 100",
          "legendFormat": "GPU {{gpu}} Tensor Active"
        },
        {
          "expr": "DCGM_FI_PROF_PIPE_FP32_ACTIVE{gpu=~\"$gpu\"} * 100",
          "legendFormat": "GPU {{gpu}} FP32 Active"
        },
        {
          "expr": "DCGM_FI_PROF_PIPE_FP16_ACTIVE{gpu=~\"$gpu\"} * 100",
          "legendFormat": "GPU {{gpu}} FP16 Active"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "max": 100 }
      }
    },
    {
      "id": 3,
      "title": "GPU Core Temperature (°C)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_GPU_TEMP{gpu=~\"$gpu\"}",
          "legendFormat": "GPU {{gpu}} Core Temp"
        },
        {
          "expr": "DCGM_FI_DEV_MEMORY_TEMP{gpu=~\"$gpu\"}",
          "legendFormat": "GPU {{gpu}} Memory Temp"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 30 },
              { "color": "yellow", "value": 75 },
              { "color": "red", "value": 85 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Power Usage vs Limit (W)",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 8, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_POWER_USAGE{gpu=~\"$gpu\"}",
          "legendFormat": "GPU {{gpu}} Power Draw"
        },
        {
          "expr": "DCGM_FI_DEV_POWER_MGMT_LIMIT{gpu=~\"$gpu\"}",
          "legendFormat": "GPU {{gpu}} Power Limit (TDP)"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "watt" } }
    },
    {
      "id": 5,
      "title": "SM Clock (MHz)",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 8, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_SM_CLOCK{gpu=~\"$gpu\"}",
          "legendFormat": "GPU {{gpu}} SM Clock"
        },
        {
          "expr": "DCGM_FI_DEV_MEM_CLOCK{gpu=~\"$gpu\"}",
          "legendFormat": "GPU {{gpu}} Mem Clock"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 6,
      "title": "GPU Memory Used (GiB)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 15, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_FB_USED{gpu=~\"$gpu\"} / 1024",
          "legendFormat": "GPU {{gpu}} FB Used"
        },
        {
          "expr": "(DCGM_FI_DEV_FB_USED{gpu=~\"$gpu\"} + DCGM_FI_DEV_FB_FREE{gpu=~\"$gpu\"}) / 1024",
          "legendFormat": "GPU {{gpu}} FB Total"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "gbytes" } }
    },
    {
      "id": 7,
      "title": "PCIe Throughput (MB/s)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 15, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(DCGM_FI_PROF_PCIE_TX_BYTES{gpu=~\"$gpu\"}[30s]) / 1e6",
          "legendFormat": "GPU {{gpu}} PCIe TX"
        },
        {
          "expr": "rate(DCGM_FI_PROF_PCIE_RX_BYTES{gpu=~\"$gpu\"}[30s]) / 1e6",
          "legendFormat": "GPU {{gpu}} PCIe RX"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "MBs" } }
    },
    {
      "id": 8,
      "title": "ECC Error Counters",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 22, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_ECC_SBE_VOL_TOTAL{gpu=~\"$gpu\"}",
          "legendFormat": "GPU {{gpu}} SBE Volatile"
        },
        {
          "expr": "DCGM_FI_DEV_ECC_DBE_VOL_TOTAL{gpu=~\"$gpu\"}",
          "legendFormat": "GPU {{gpu}} DBE Volatile"
        },
        {
          "expr": "DCGM_FI_DEV_ECC_SBE_AGG_TOTAL{gpu=~\"$gpu\"}",
          "legendFormat": "GPU {{gpu}} SBE Aggregate"
        },
        {
          "expr": "DCGM_FI_DEV_ECC_DBE_AGG_TOTAL{gpu=~\"$gpu\"}",
          "legendFormat": "GPU {{gpu}} DBE Aggregate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }]
          }
        }
      }
    },
    {
      "id": 9,
      "title": "Retired Pages",
      "type": "stat",
      "gridPos": { "x": 12, "y": 22, "w": 6, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_RETIRED_SBE{gpu=~\"$gpu\"}",
          "legendFormat": "Retired (SBE) GPU {{gpu}}"
        },
        {
          "expr": "DCGM_FI_DEV_RETIRED_DBE{gpu=~\"$gpu\"}",
          "legendFormat": "Retired (DBE) GPU {{gpu}}"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }, { "color": "red", "value": 10 }]
          }
        }
      }
    },
    {
      "id": 10,
      "title": "Throttle State",
      "type": "stat",
      "gridPos": { "x": 18, "y": 22, "w": 6, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_POWER_VIOLATION{gpu=~\"$gpu\"}",
          "legendFormat": "Power Throttle GPU {{gpu}}"
        },
        {
          "expr": "DCGM_FI_DEV_THERMAL_VIOLATION{gpu=~\"$gpu\"}",
          "legendFormat": "Thermal Throttle GPU {{gpu}}"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "mappings": [{ "type": "value", "options": { "0": { "text": "OK", "color": "green" } } }],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }]
          }
        }
      }
    }
  ]
}
